# GMAO Environment Configuration Template
# Copy this to .env and update values for your environment

# Application
NODE_ENV=production
PORT=3001
BACKEND_PORT=3001

# Database
MONGODB_URI=mongodb://localhost:27017/GMAO_IPROTEX
MONGODB_ROOT_USER=
MONGODB_ROOT_PASSWORD=
MONGODB_DATABASE=GMAO_IPROTEX
MONGODB_PORT=27017

# Redis
REDIS_URL=redis://:changeme@redis:6379
REDIS_PASSWORD=changeme
REDIS_PORT=6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-long-change-me
JWT_REFRESH_SECRET=your-super-secret-refresh-jwt-key-min-32-chars-long-change-me
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGINS=https://your-frontend.vercel.app

# Audit Retention (days)
AUDIT_RETENTION_DAYS_INFO=30
AUDIT_RETENTION_DAYS_WARNING=60
AUDIT_RETENTION_DAYS_SECURITY=180
AUDIT_RETENTION_DAYS_CRITICAL=365

# Nginx
NGINX_PORT=80
NGINX_SSL_PORT=443

# Email / SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_REJECT_UNAUTHORIZED=false
EMAIL_FROM="no-reply@yourdomain.com"
APP_URL=http://localhost:3000
DEFAULT_LOCALE=en

# Optional: S3 or other cloud storage for uploads
# AWS_ACCESS_KEY_ID=your_key
# AWS_SECRET_ACCESS_KEY=your_secret
# AWS_BUCKET_NAME=your_bucket
# AWS_REGION=us-east-1
