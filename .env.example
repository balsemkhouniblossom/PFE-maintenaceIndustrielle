# GMAO Environment Configuration Template
# Use this template for .env.local (local dev) and .env.production (production).
# Optional future profile: .env.staging

# Application
NODE_ENV=development
PORT=3001
BACKEND_PORT=3001

# Database
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-host>/GMAO_IPROTEX?retryWrites=true&w=majority
MONGODB_ROOT_USER=
MONGODB_ROOT_PASSWORD=
MONGODB_DATABASE=GMAO_IPROTEX
MONGODB_PORT=27017

# Redis
REDIS_URL=redis://:changeme@redis:6379
REDIS_PASSWORD=changeme
REDIS_PORT=6379

# JWT
JWT_SECRET=e4319bf2da070c11255078c32ab45f66921360503b85192c34278f01e6c2fce46dc4a29290a84659bf09eb98811edab283b028b0aeee29b6f6f27a27ba332658
JWT_REFRESH_SECRET=9b7d3a1c2e4f567890abcdef1234567890abcdef1234567890abcdef1234
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
EMAIL_VERIFICATION_SECRET=005acec7d2f2eb7964c8538209f9f2b7af31cc8227d260c1320c0bc1eb5d6fd19e71a25d79a1540332ef5e5574bf142f2372f3392bf6d09e394b79efbdb44471

# Feature flags for phased rollout
ENABLE_LEGACY_EMAIL_TOKENS=true
ENABLE_EVENT_BASED_EMAILS=false

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,https://your-frontend.vercel.app,https://your-frontend-*.vercel.app
# Audit Retention (days)
AUDIT_RETENTION_DAYS_INFO=30
AUDIT_RETENTION_DAYS_WARNING=60
AUDIT_RETENTION_DAYS_SECURITY=180
AUDIT_RETENTION_DAYS_CRITICAL=365

# Nginx
NGINX_PORT=80
NGINX_SSL_PORT=443

# Email / SMTP
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_PASS_EXISTS=true
SMTP_REJECT_UNAUTHORIZED=true
EMAIL_FROM="Iprotex <noreply@your-domain.com>"
API_URL=https://your-backend.example.com
APP_URL=https://your-frontend.example.com
FRONTEND_BASE_URL=https://your-frontend.example.com
DEFAULT_LOCALE=en

# Optional: S3 or other cloud storage for uploads
# AWS_ACCESS_KEY_ID=your_key
# AWS_SECRET_ACCESS_KEY=your_secret
# AWS_BUCKET_NAME=your_bucket
# AWS_REGION=us-east-1
